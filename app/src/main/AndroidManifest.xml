<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos esenciales -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Solicitar exención de optimización de batería — necesario para que AppMonitorService
         y DnsFilterService permanezcan activos continuamente sin que el sistema los mate.
         Sin esta exención, Android puede suspender la protección parental en segundo plano.
         Justificación Play Store: la app de control parental debe monitorizar en tiempo real
         las 24h; la exención es imprescindible para garantizar la protección del menor. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- 🔴 ANDROID 14+ (API 34): Permisos foreground service connectedDevice -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    
    <!-- 🔴 CRÍTICO: Permiso para UsageStatsMonitor -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" 
                     tools:ignore="ProtectedPermissions" />
    
    <!-- Permiso para cerrar apps en segundo plano (control parental) -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />

    <!-- 🔴 Overlay sobre otras apps — requerido para mostrar la pantalla de bloqueo parental
         sobre apps restringidas. AppBlockerAccessibilityService verifica canDrawOverlays()
         y redirige al usuario a ACTION_MANAGE_OVERLAY_PERMISSION si no está concedido.
         Justificación Play Store: control parental — bloqueo visual de apps prohibidas para menores. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- Para detectar apps instaladas por el menor y mostrar lista de selección en el panel
         parental (SensitiveAppEntity). Sin este permiso, en Android 11+ el sistema oculta
         apps de otros desarrolladores al listarlas con packageManager.
         Justificación Play Store: control parental — permite al tutor seleccionar qué apps
         del dispositivo del menor deben ser monitorizadas o bloqueadas. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GuardianShield"
        android:networkSecurityConfig="@xml/network_security_config"
        android:termsOfServiceUrl="https://guardianos.es/terminos"
        tools:targetApi="31">

        <!-- Actividad Principal -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.GuardianShield">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🔒 Navegador seguro (NO exported - solo uso interno) -->
        <activity
            android:name=".ui.SafeBrowserActivity"
            android:exported="false"
            android:theme="@style/Theme.GuardianShield"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize" />

        <!-- 🚫 Pantalla de bloqueo de apps (lanzada por el Accessibility Service) -->
        <activity
            android:name=".ui.AppBlockedActivity"
            android:exported="false"
            android:theme="@style/Theme.GuardianShield"
            android:showOnLockScreen="true"
            android:excludeFromRecents="true"
            android:configChanges="orientation|screenSize" />

        <!-- Servicio VPN para filtrado DNS -->
        <service
            android:name=".service.DnsFilterService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="connectedDevice"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- 🔴 SERVICIO CRÍTICO: Monitoreo estable con UsageStats -->
        <service
            android:name=".service.AppMonitorService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- Servicio ligero de monitoreo (modo recomendado) -->
        <service
            android:name=".service.LightweightMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- ♿ Servicio de accesibilidad — bloqueo real de apps instaladas sin root -->
        <service
            android:name=".service.AppBlockerAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 🔐 Device Admin — anti-tampering (evita desinstalación sin PIN parental) -->
        <receiver
            android:name=".security.GuardianDeviceAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- ⚠️ RealisticAppBlocker NO es un Service - es una clase utilitaria -->
        <!-- ⚠️ ScheduleManager NO es un Service - es una clase de lógica -->
        <!-- ❌ ELIMINA estas declaraciones si existen como <service> -->

    </application>

</manifest>
