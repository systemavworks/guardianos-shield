    <!-- Setup steps -->
    <string name="help_step1_title">Activate the network filter (VPN)</string>
    <string name="help_step1_desc">Tap the large button on the main panel to turn on protection. The first time, the system will ask for permission — accept it.</string>
    <string name="help_step1_where">Main screen → central button</string>

    <string name="help_step2_title">Create a 4-digit parental PIN</string>
    <string name="help_step2_desc">The PIN protects access to the Parental Controls and Filters sections, preventing your child from changing the settings. Choose one only you know.</string>
    <string name="help_step2_where">Parental Controls → Child profile → Parental PIN</string>

    <string name="help_step3_title">Activate app monitoring</string>
    <string name="help_step3_desc">Allows the app to know which applications your child uses. If the system requests a special Usage Statistics permission, accept it.</string>
    <string name="help_step3_where">Main screen → Monitoring section</string>

    <string name="help_step4_title">Activate app blocking (Accessibility)</string>
    <string name="help_step4_desc">Go to phone Settings → Accessibility → General → Downloaded Apps → GuardianOS Shield and enable it. You only need to do this once.</string>
    <string name="help_step4_where">Phone Settings → Accessibility → General → Downloaded Apps</string>

    <string name="help_step5_title">Set up your child\'s profile</string>
    <string name="help_step5_desc">Enter the child\'s name and age and set the hours when they can use the phone.</string>
    <string name="help_step5_where">Parental Controls → Profile</string>

    <!-- Features -->
    <string name="help_feat1_title">DNS Filter (network protection)</string>
    <string name="help_feat1_summary">Automatically blocks dangerous websites</string>
    <string name="help_feat1_detail">When your child browses the internet, all websites first pass through a specialized filter (CleanBrowsing). If the site contains adult content, violence, gambling, malware or social media, the filter blocks it before it loads. It works in any browser on the phone, not just GuardianOS\'s own browser.</string>

    <string name="help_feat2_title">Built-in safe browser</string>
    <string name="help_feat2_summary">A browser with extra protection for your child</string>
    <string name="help_feat2_detail">GuardianOS includes its own web browser with an extra layer of security. It automatically activates strict SafeSearch on Google and Bing, and Restricted Mode on YouTube. If a dangerous site is opened, a block screen explains why it cannot be accessed. It\'s the safest place for your child to browse.</string>

    <string name="help_feat3_title">App blocking</string>
    <string name="help_feat3_summary">Automatically closes disallowed apps</string>
    <string name="help_feat3_detail">When your child opens a blocked app (Instagram, TikTok, WhatsApp, games, gambling, etc.), GuardianOS closes it instantly and shows a screen explaining why it\'s blocked. It also detects VPN and proxy bypass attempts and blocks them without exception. For this to work, you need to enable the accessibility permission once (step 4 of setup).</string>

    <string name="help_feat4_title">Schedule control</string>
    <string name="help_feat4_summary">Define when they can use the phone</string>
    <string name="help_feat4_detail">Set a time window (for example, 4:00 PM to 8:00 PM) during which your child can use the phone normally. Outside that window, blocked apps close automatically and the web filter becomes stricter. Schedules that cross midnight are also supported.</string>

    <string name="help_feat5_title">Statistics &amp; history</string>
    <string name="help_feat5_summary">See what your child tried to open</string>
    <string name="help_feat5_detail">The Statistics section shows a summary of all blocked websites and apps, organized by day, week or month. You can see how many times they tried to access social media, which websites were blocked and in which categories. Premium users have access to 30 days of history.</string>

    <string name="help_feat6_title">Streak system (TrustFlow)</string>
    <string name="help_feat6_summary">Rewards good behavior</string>
    <string name="help_feat6_detail">If your child does not try to bypass restrictions for several days in a row, the system gradually gives them more autonomy. With a 7-day streak they enter Explorer Mode (a warning is shown before blocking). With 30 days they become a Guardian and get 60 minutes of free access per day. This encourages compliance without conflict.</string>

    <string name="help_feat7_title">Block by category</string>
    <string name="help_feat7_summary">Choose what type of content to block</string>
    <string name="help_feat7_detail">In Parental Controls you can enable or disable blocks by category: adult content, gambling and casino, social media and video games. Educational apps (Duolingo, Khan Academy, YouTube Kids, Toca Boca, etc.) are whitelisted and never blocked even if the games toggle is on.</string>

    <string name="help_feat8_title">Play Store outside allowed hours</string>
    <string name="help_feat8_summary">Prevents unauthorized installs</string>
    <string name="help_feat8_detail">GuardianOS detects when your child opens the Google Play Store outside allowed hours and blocks it automatically. This prevents them from installing new apps when they shouldn\'t be using the phone.</string>

    <string name="help_feat9_title">Anti-bypass VPN blocking</string>
    <string name="help_feat9_summary">Closes VPNs and proxies trying to bypass the filter</string>
    <string name="help_feat9_detail">GuardianOS automatically detects and blocks the main bypass attempts: Psiphon, Turbo VPN, Orbot/Tor, ProtonVPN, Hotspot Shield, Cloudflare Warp and others. When your child tries to open one of these apps, it closes instantly, is recorded in the history and you receive an urgent alert. Blocking is unconditional.</string>

    <string name="help_feat10_title">Weekly parent summary</string>
    <string name="help_feat10_summary">Automatic report every Sunday</string>
    <string name="help_feat10_detail">Without opening the app, you receive a weekly notification with an activity summary: how many websites were blocked, attempts to open social media, games, and whether there were any VPN bypass attempts. It\'s the report that gives you peace of mind knowing everything is working.</string>

    <string name="help_feat11_title">Family Digital Pact</string>
    <string name="help_feat11_summary">Your child can request permissions from you</string>
    <string name="help_feat11_detail">Instead of bypassing restrictions, your child can send a request for you to approve or reject: more screen time or access to a specific website. You respond with your PIN. This encourages communication rather than conflict.</string>

    <!-- FAQs -->
    <string name="help_faq1_q">Does the app need internet to work?</string>
    <string name="help_faq1_a">The network filter does require an internet connection (it is based on external DNS servers that block content). However, app blocking and schedule control work offline, directly on the phone.</string>

    <string name="help_faq2_q">My child turned off WiFi and kept browsing — why?</string>
    <string name="help_faq2_a">The DNS filter only works when the GuardianOS VPN is active and connected (WiFi or mobile data). If your child activates airplane mode or turns off data, the network filter cannot act. To prevent this, also enable app blocking (accessibility service) and add system settings to blocked apps.</string>

    <string name="help_faq3_q">Can my child uninstall GuardianOS?</string>
    <string name="help_faq3_a">If you activate Device Administrator mode (in Settings → Advanced Security → Anti-uninstall), your child will not be able to uninstall the app without entering the parental PIN. It is an extra protection layer that is recommended.</string>

    <string name="help_faq4_q">The app blocked something it shouldn\'t — what do I do?</string>
    <string name="help_faq4_a">You can add that domain to the whitelist in Custom Filters → Allowed list. You can also review the active categories in Parental Controls to adjust what types of content are blocked.</string>

    <string name="help_faq5_q">Why does it need the Accessibility permission?</string>
    <string name="help_faq5_a">The accessibility permission is the only way to close other applications on Android without root. GuardianOS uses it exclusively to block the apps you configure. It does not read screen content or access passwords.</string>

    <string name="help_faq6_q">Does it work with Netflix, YouTube or Spotify?</string>
    <string name="help_faq6_a">GuardianOS controls screen time through schedules. The accessibility service detects if any app is active outside allowed hours and returns the child to the home screen, which also applies to Netflix, YouTube, Spotify and similar apps. The DNS filter does not act on these apps because they use encrypted protocols, but the schedule-based block does apply.</string>

    <string name="help_faq7_q">What if my child has more than one phone?</string>
    <string name="help_faq7_a">GuardianOS must be installed on each device you want to protect. Configuration and statistics are independent per device. The Premium license (one-time payment) is valid for a single device.</string>

    <string name="help_faq8_q">Does the app drain the battery?</string>
    <string name="help_faq8_a">The battery impact is minimal. To prevent the system from stopping the service, go to phone Settings → Battery → Battery optimization → GuardianOS Shield → Unrestricted. This is especially important on OPPO, Xiaomi and Huawei phones.</string>

    <string name="help_faq9_q">Can my child use a VPN to bypass the filter?</string>
    <string name="help_faq9_a">GuardianOS automatically detects and blocks the main VPN and bypass apps: Psiphon, Turbo VPN, Orbot/Tor, Hotspot Shield, ProtonVPN, Cloudflare Warp and others. If your child tries to open any of them, it is blocked instantly and logged with an urgent alert for you.</string>

    <!-- Tips -->
    <string name="help_tip1_title">Exclude GuardianOS from battery optimization</string>
    <string name="help_tip1_desc">Go to phone Settings → Battery → Battery optimization. Find GuardianOS Shield and select Unrestricted or Don\'t optimize. If you don\'t, the system may automatically shut down the monitoring service.</string>

    <string name="help_tip2_title">Set a strong PIN — don\'t share it with your child</string>
    <string name="help_tip2_desc">Avoid birthdays or other easy combinations. The PIN protects access to Parental Controls and Filters. Without it, your child can change settings freely.</string>

    <string name="help_tip3_title">On OPPO, Xiaomi and Huawei: enable restricted settings</string>
    <string name="help_tip3_desc">On these phones, go to Settings → Apps → GuardianOS Shield → three dots (⋮) → Allow restricted settings. Without this step, app blocking may not work correctly.</string>

    <string name="help_tip4_title">The network filter doesn\'t work without a connection</string>
    <string name="help_tip4_desc">GuardianOS\'s VPN requires active data (WiFi or mobile data) to filter websites. Complement with app blocking for more complete protection when there is no network.</string>

    <string name="help_tip5_title">Talk to your child about the rules</string>
    <string name="help_tip5_desc">Technology helps, but conversation is essential. Explain why the restrictions exist and establish clear usage rules. The Family Digital Pact in the app is a great tool to do it together.</string>

