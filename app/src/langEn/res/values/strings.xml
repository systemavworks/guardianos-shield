    <string name="about_feat3_title">App blocking · Premium</string>
    <string name="about_feat3_subtitle">Prevents opening Instagram, TikTok, etc. outside allowed hours using accessibility.</string>
    <string name="about_feat4_title">Category-based blocking</string>
    <string name="about_feat4_subtitle">Control by category: adult content, gambling, social networks and video games. Educational apps (Duolingo, Khan Academy, etc.) are never blocked.</string>
    <string name="about_feat5_title">Play Store outside hours</string>
    <string name="about_feat5_subtitle">Blocks access to Google Play Store outside allowed hours to prevent unauthorised installations.</string>
    <string name="about_feat6_title">Automatic VPN anti-evasion</string>
    <string name="about_feat6_subtitle">Instantly detects and blocks VPN and proxy apps (Psiphon, Turbo VPN, Orbot, Hotspot Shield…) and alerts the parent.</string>
